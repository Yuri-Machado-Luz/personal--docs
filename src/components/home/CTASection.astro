---
import { EmailRaw, GitHubRaw, LinkedInRaw } from "@assets";
import { CONFIG } from "@config";
import Button from "@ui/Button.astro";
---

<section
  id="cta-section"
  class="relative isolate mb-32 flex items-center justify-center gap-6 py-32"
>
  <div class="container text-center">
    <h2 class="section-title mb-8 font-medium">
      Tem um projeto em mente ou quer conversar?
    </h2>

    <Button href="/contato" style={{ variant: "primary", size: "xl" }}>
      Entre em contato!
    </Button>

    <nav class="social-links mt-6 justify-center fill-accent text-accent">
      <a
        href={`mailto:yurimachadoluz@gmail.com?subject=Forms%20-%20Portfolio
`}
        class="social-link text-white text-xl"
        rel="noopener noreferrer"
        target="_blank"
      >
        <span class="text-white h-14 w-14" aria-hidden set:html={EmailRaw} />
      </a>
      <a
        href={CONFIG.meta.social.github}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link text-xl"
      >
        <span class="text-white h-16 w-16" aria-hidden set:html={GitHubRaw} />
      </a>
      <a
        href={CONFIG.meta.social.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="social-link text-white text-xl"
      >
        <span class="text-white h-14 w-14" aria-hidden set:html={LinkedInRaw} />
      </a>
    </nav>
  </div>
</section>
