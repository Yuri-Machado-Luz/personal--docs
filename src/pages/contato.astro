---
import { Base } from "@layouts";
import Contact from "@ui/Contact.astro";
---

<Base
  title="Contato — Yuri Machado Luz"
  description="Entre em contato com Yuri Machado Luz para projetos de desenvolvimento web, automação ou consultoria."
>
  <main id="sobre-main">
    <Contact />
  </main>
</Base>

<script>
  import gsap from "gsap";
import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  let ctx: gsap.Context | null = null;

  function init() {
    const main = document.querySelector<HTMLElement>("#sobre-main");
    if (!main) return;

    ctx?.revert();

    ctx = gsap.context(() => {
      gsap.set(".sobre-header", { autoAlpha: 0, y: 24 });
      gsap.to(".sobre-header", {
        autoAlpha: 1,
        y: 0,
        duration: 0.7,
        ease: "power3.out",
        delay: 0.1,
      });

      gsap.set(".bio-paragraph", { autoAlpha: 0, y: 16 });
      ScrollTrigger.batch(".bio-paragraph", {
        onEnter: (els) =>
          gsap.to(els, {
            autoAlpha: 1,
            y: 0,
            duration: 0.55,
            stagger: 0.08,
            ease: "power2.out",
          }),
        once: true,
        start: "top 90%",
      });

      gsap.set(".experience-item", { autoAlpha: 0, x: -20 });
      ScrollTrigger.batch(".experience-item", {
        onEnter: (els) =>
          gsap.to(els, {
            autoAlpha: 1,
            x: 0,
            duration: 0.55,
            stagger: 0.1,
            ease: "power3.out",
          }),
        once: true,
        start: "top 88%",
      });

      gsap.set(".education-item, .language-card", { autoAlpha: 0, y: 20 });
      ScrollTrigger.batch(".education-item, .language-card", {
        onEnter: (els) =>
          gsap.to(els, {
            autoAlpha: 1,
            y: 0,
            duration: 0.45,
            stagger: 0.07,
            ease: "power2.out",
          }),
        once: true,
        start: "top 90%",
      });
    }, main);

    // Hash-tracking via IntersectionObserver
    const ids = ["bio", "habilidades", "experiencia", "formacao", "idiomas", "contato"];
    const sections = ids
      .map((id) => document.getElementById(id))
      .filter(Boolean) as HTMLElement[];

    if (sections.length > 0) {
      const observer = new IntersectionObserver(
        (entries) => {
          for (const entry of entries) {
            if (entry.isIntersecting) {
              history.replaceState(null, "", `#${entry.target.id}`);
              break;
            }
          }
        },
        { rootMargin: "-40% 0px -55% 0px" },
      );
      sections.forEach((s) => observer.observe(s));
      // Cleanup handled by astro:before-preparation → ctx.revert() kills GSAP,
      // but IntersectionObserver needs manual disconnect.
      document.addEventListener(
        "astro:before-preparation",
        () => observer.disconnect(),
        { once: true },
      );
    }

    ScrollTrigger.refresh();
  }

  document.addEventListener("astro:page-load", init);
  document.addEventListener("astro:before-preparation", () => ctx?.revert());
</script>
